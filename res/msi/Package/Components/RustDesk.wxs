				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/window_size_plugin.dll" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="270db7db-c5e0-4135-9fba-0bcd8b59d85a" Subdirectory="data">
				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/data/app.so" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="ca6b0a22-8d6b-46dd-abf3-e083d9f70ec3" Subdirectory="data">
