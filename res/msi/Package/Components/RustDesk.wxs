			</Component>
			<Component Guid="d419097c-0da7-4679-8a04-a4e3a3a9e75c" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/address_book.ttf" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="a5a1dd4e-9bca-4be3-ba60-50846da2119e" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/android.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="e3fca373-b8e3-4cbc-9396-223f4204a7d2" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/arrow.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="628f0929-1147-4fa4-b4c8-783033bf7684" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/auth-apple.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="cffa79fa-2a38-4fb3-8f34-f9b9126c04fa" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/auth-auth0.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="fee1884d-3bb5-400f-a424-0bc57ab144b3" Subdirectory="data\flutter_assets\assets">
