				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/actions.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="5dd118fc-0558-466e-9e8c-7fae6944995f" Subdirectory="data\flutter_assets\assets">
