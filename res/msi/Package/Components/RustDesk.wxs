			</Component>
			<Component Guid="10eb3358-2018-4da4-9d4f-7da4bf093913" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/chevron_up_chevron_down.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="57ff987c-f6c9-4769-b16e-b349d9f813e0" Subdirectory="data\flutter_assets\assets">
