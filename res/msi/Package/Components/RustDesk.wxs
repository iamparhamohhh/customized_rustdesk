				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/uni_links_desktop_plugin.dll" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="1d955450-f578-4ecb-ba4b-1adef9b948be" >
