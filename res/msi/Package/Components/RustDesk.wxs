				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/flutter_windows.dll" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="8a3e7985-979b-437f-bee8-90d4a37e24e9" >
				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/librustdesk.dll" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="5029d624-7910-47a1-a27e-07f03f2bfd14" >
				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/screen_retriever_plugin.dll" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="8c4c8126-fe54-4500-8adc-1cd86b9e4420" >
