			</Component>
			<Component Guid="eb37e530-3159-4a23-b181-145c4ddfed97" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/auth-default.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="9037fcf4-8586-49ec-9c64-7194340cee9b" Subdirectory="data\flutter_assets\assets">
				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/assets/auth-facebook.svg" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="7e5d4831-e1a7-45f8-bdfe-1f3eebc37958" Subdirectory="data\flutter_assets\assets">
