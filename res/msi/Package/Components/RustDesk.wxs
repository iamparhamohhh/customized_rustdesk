			</Component>
			<Component Guid="b4cf2e22-8761-4b7d-b746-f5cc042b7102" Subdirectory="data\flutter_assets">
				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/FontManifest.json" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="26d3080f-f0be-4819-b5f6-8a79a145afea" Subdirectory="data\flutter_assets">
				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/NativeAssetsManifest.json" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="a7ac43d0-e825-41dd-854b-43b1a9e08421" Subdirectory="data\flutter_assets">
				<File Source="E:/customized_rustdesk/flutter/build/windows/x64/runner/Release/data/flutter_assets/NOTICES.Z" KeyPath="yes" Checksum="yes" />
			</Component>
